{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lewdware.github.com/config.schema.json",
  "title": "Mode Config",
  "description": "Configuration file for a mode",
  "type": "object",
  "properties": {
    "name": {
      "description": "The name of the mode file",
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "include": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "modes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/mode"
      }
    }
  },
  "required": ["name", "modes"],

  "$defs": {
    "mode": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "entrypoint": {
          "type": "string",
          "description": "The path to the main lua file for the mode"
        },
        "options": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/entry"
          }
        }
      },
      "required": ["name", "entrypoint"]
    },

    "condition_value": {
      "description": "A primitive value used in a show_when condition",
      "oneOf": [
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string" }
      ]
    },

    "show_when": {
      "description": "Map of option keys to required values. All conditions must match for this entry to be visible. null values never satisfy any condition.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/condition_value"
      }
    },

    "entry": {
      "oneOf": [
        { "$ref": "#/$defs/option" },
        { "$ref": "#/$defs/group" }
      ]
    },

    "group": {
      "type": "object",
      "description": "A collapsible group of options",
      "properties": {
        "type": { "const": "group" },
        "label": {
          "type": "string",
          "description": "The heading shown to the user"
        },
        "description": {
          "type": "string"
        },
        "show_when": {
          "$ref": "#/$defs/show_when"
        },
        "options": {
          "type": "object",
          "description": "The options inside this group",
          "additionalProperties": {
            "$ref": "#/$defs/option"
          }
        }
      },
      "required": ["type", "label", "options"],
      "unevaluatedProperties": false
    },

    "option": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string",
          "description": "The label shown to the user"
        },
        "description": {
          "type": "string",
          "description": "An optional description shown below the label"
        },
        "optional": {
          "type": "boolean",
          "description": "If true, the value may be null/disabled. Use \"enabled_by_default\" to control the initial state."
        },
        "enabled_by_default": {
          "type": "boolean",
          "description": "For optional options: whether the option starts enabled. Defaults to false."
        },
        "show_when": {
          "$ref": "#/$defs/show_when"
        },
        "type": {
          "enum": ["integer", "number", "string", "boolean", "enum"]
        }
      },
      "required": ["label", "type"],
      "oneOf": [
        {
          "properties": {
            "type": { "const": "integer" },
            "default": { "type": "integer" },
            "min": { "type": "integer" },
            "max": { "type": "integer" },
            "step": { "type": "integer" },
            "clamp": { "type": "boolean" },
            "slider": { "type": "boolean" }
          },
          "required": ["default"]
        },
        {
          "properties": {
            "type": { "const": "number" },
            "default": { "type": "number" },
            "min": { "type": "number" },
            "max": { "type": "number" },
            "step": { "type": "number" },
            "clamp": { "type": "boolean" },
            "slider": { "type": "boolean" }
          },
          "required": ["default"]
        },
        {
          "properties": {
            "type": { "const": "string" },
            "default": { "type": "string" }
          },
          "required": ["default"]
        },
        {
          "properties": {
            "type": { "const": "boolean" },
            "default": { "type": "boolean" }
          },
          "required": ["default"]
        },
        {
          "properties": {
            "type": { "const": "enum" },
            "values": {
              "type": "object",
              "additionalProperties": {
                "type": "string",
                "description": "The label shown to the user"
              },
              "minProperties": 1
            },
            "default": { "type": "string" }
          },
          "required": ["values", "default"]
        }
      ],
      "unevaluatedProperties": false
    }
  }
}
